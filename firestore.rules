rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regras para os perfis de usuários
    match /users/{userId} {
      // Permite se for o próprio usuário OU se quem estiver logado tiver o role 'admin'
      allow read, write: if request.auth != null && (
        request.auth.uid == userId || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }
    
    // Regras para o registro de ponto
    match /batidas/{batidaId} {
      // Colaborador pode ler seus próprios pontos; Admin pode ler os pontos de todo mundo
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.uid || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
      
      // Apenas o próprio usuário pode registrar (escrever) um ponto no seu nome
      allow write: if request.auth != null && request.auth.uid == request.resource.data.uid;
    }
    
  }
}
