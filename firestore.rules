rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regras para os perfis de usuários
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
    }
    
    // Regras para o registro de ponto
    match /batidas/{batidaId} {
      // Permite ler o próprio ponto ou se for admin
      allow read: if request.auth != null && (request.auth.uid == resource.data.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
      
      // PERMISSÃO DE ESCRITA: 
      // Permite criar se o usuário estiver autenticado e o 'uid' no documento for o mesmo do usuário logado
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update, delete: if false; // Por segurança, não permitimos alterar pontos já batidos
    }
  }
}
